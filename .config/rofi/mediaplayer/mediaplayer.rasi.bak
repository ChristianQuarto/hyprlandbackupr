
configuration {
    show-icons: false;
}

@import "~/.config/rofi/colors/shared.rasi"

window {
    transparency:     "real";
    location:         north;
    anchor:           north;
    fullscreen:       false;
    height:           400px;
    width:            300px;
    x-offset:         0px;
    y-offset:         50px;
    margin:           0px;
    padding:          0px;
    border:           2px solid;
    border-radius:    20px;
    border-color:     @selected;
    background-color: @background;
}

mainbox {
    spacing:          12px;
    padding:          20px;
    background-color: transparent;
    children:         [ "imagebox", "message", "listview" ];
}

imagebox {
    padding:          0px;
    background-color: transparent;
    background-image: url("~/.cache/rofi-mediaplayer/cover.png", width);
    border-radius:    12px;
    height:           200px;
    orientation:      vertical;
    children:         [];
}

message {
    padding:          10px;
    border-radius:    12px;
    background-color: @background-alt;
    text-color:       @foreground;
}

textbox {
    background-color: transparent;
    text-color:       @foreground;
    vertical-align:   0.5;
    horizontal-align: 0.5;
    markup:           true;
}

listview {
    columns:          5;
    lines:            1;
    cycle:            true;
    scrollbar:        false;
    fixed-height:     true;
    spacing:          8px;
    background-color: transparent;
}

element {
    padding:          12px;
    border-radius:    12px;
    background-color: @background-alt;
    text-color:       @foreground;
    cursor:           pointer;
    orientation:      vertical;
}

element-text {
    background-color: transparent;
    text-color:       inherit;
    vertical-align:   0.5;
    horizontal-align: 0.5;
    font:             "JetBrainsMono Nerd Font 16";
}

element selected.normal {
    background-color: @selected;
    text-color:       @background;
}

